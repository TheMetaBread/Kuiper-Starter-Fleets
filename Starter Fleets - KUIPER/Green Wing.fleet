  <CraftTypes>
    <CraftTemplate>
      <Nickname>Cubesat</Nickname>
      <LongDescription>$CRAFTSTAT_FRAMEMODEL: Cubesat
$CRAFTSTAT_FRAMECLASS: Utility Drone
$CRAFTSTAT_BASECOST: 5
$CRAFTSTAT_STORAGESIZE: 1
$CRAFTSTAT_PADSIZE: 3 x 3
$CRAFTSTAT_PDTHREATSIZE: 1

$CRAFTSTAT_HEALTH: 50 
$CRAFTSTAT_SKIN: 0.5 $UNIT_MILLIMETERS
$CRAFTSTAT_TARGETSIZE: 1 
$CRAFTSTAT_DR: 0.5 %

$CRAFTSTAT_RADARSIG: 100 %
$CRAFTSTAT_WAKESIG: 100 %
$CRAFTSTAT_MISSILESBOMBS
$CRAFTSTAT_CMDCAPACITY: -1 
$CRAFTSTAT_MISSILEANGLE: 30 $UNIT_DEGREES
$CRAFTSTAT_BOMBLEVELTIME: 3 $UNIT_SECONDS_MED

$CRAFTSTAT_PREFLIGHTTIME
$CRAFTSTAT_PREFLIGHT_NOSHIPS

$CRAFTSTAT_IDLESPEED: 50 $UNIT_METERSPERSEC
$CRAFTSTAT_CRUISESPEED: 50 $UNIT_METERSPERSEC
$CRAFTSTAT_HBRNSPEED: 50 $UNIT_METERSPERSEC
$CRAFTSTAT_COMBATSPEED: 50 $UNIT_METERSPERSEC

$CRAFTSTAT_FUELCAPACITY: 120
$CRAFTSTAT_LOITERTIME: 08:00
$CRAFTSTAT_CRUISERANGE: 24 $UNIT_KILOMETERS

$CRAFTSTAT_THRUSTERPOWER: 250 
$CRAFTSTAT_TURNRATE: 90 
$CRAFTSTAT_FRAMEMASS: 25.00
$CRAFTSTAT_LOADOUTMASS: -
$CRAFTSTAT_TOTALMASS: 25.00

&lt;b&gt;Components:&lt;/b&gt;
Countermeasures: Standard CM Launcher

&lt;b&gt;Loadouts:&lt;/b&gt;
Point Defense: 150x &lt;noparse&gt;40mm HE-RPF Coilgun Shell&lt;/noparse&gt;
Comms Jamming
Radar Jamming
EO Jammer
Radar</LongDescription>
      <Cost>5</Cost>
      <FrameKey>KUIPER/CBU-40 Cubesat Utility Drone</FrameKey>
      <TemplateKey>b8d4b5a0-135e-4a36-b4a7-3e37503a747b</TemplateKey>
      <InstalledComponents>
        <SerializedCraftSocket>
          <SocketKey>countermeasures</SocketKey>
          <ComponentKey>cml-standard</ComponentKey>
        </SerializedCraftSocket>
      </InstalledComponents>
      <Loadouts>
        <CraftLoadout>
          <LoadoutName>Point Defense</LoadoutName>
          <Elements>
            <GeneralLoadoutElement xsi:type="SimpleOccupiedElement" />
            <GeneralLoadoutElement xsi:type="VariableSocketLoadout">
              <SocketKey>pod</SocketKey>
              <ComponentKey>40mm</ComponentKey>
              <Loadout xsi:type="SimpleAmmoSelection">
                <SocketKey>pod</SocketKey>
                <AmmoKey>KUIPER/40mm HE-RPF Shell</AmmoKey>
              </Loadout>
            </GeneralLoadoutElement>
          </Elements>
        </CraftLoadout>
        <CraftLoadout>
          <LoadoutName>Comms Jamming</LoadoutName>
          <Elements>
            <GeneralLoadoutElement xsi:type="SimpleOccupiedElement" />
            <GeneralLoadoutElement xsi:type="VariableSocketLoadout">
